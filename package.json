{
  "name": "docksentinel",
  "private": true,
  "version": "2.5.1",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "bash scripts/dev-all.sh",
    "publish": "node scripts/publish.mjs",
    "publish:beta": "node scripts/publish.mjs beta",
    "publish:alpha": "node scripts/publish.mjs alpha",
    "publish:release": "node scripts/publish.mjs release",
    "version:current": "node scripts/version.mjs",
    "tag:latest": "node scripts/tag-latest.mjs",
    "test:scripts": "node --test scripts/tests/release-utils.test.mjs && bash scripts/tests/publish-release.integration.sh"
  },
  "dependencies": {
    "@tanstack/react-table": "^8.21.3"
  }
}
